<section class="section" id="performance">
  <div class="section-header">
    <div class="section-num">12</div>
    <div class="section-title-wrap">
      <div class="section-tag">Performance Engineering</div>
      <h1 class="section-title">Advanced Performance Engineering</h1>
      <p class="section-desc">React render optimization, Fabric internals, bundle splitting, startup optimization, FlashList, Reanimated, Skia, and production profiling workflows.</p>
