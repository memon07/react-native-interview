<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>React Native Staff Engineer Manual 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --bg2: #0f0f1a;
  --bg3: #13131f;
  --surface: #1a1a2e;
  --surface2: #16213e;
  --border: #2a2a4a;
  --accent: #00d4ff;
  --accent2: #7c3aed;
  --accent3: #f59e0b;
  --accent4: #10b981;
  --danger: #ef4444;
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --code-bg: #0d1117;
  --code-border: #30363d;
  --font-head: 'Syne', sans-serif;
  --font-mono: 'JetBrains Mono', 'Space Mono', monospace;
  --font-body: 'Space Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 13.5px;
  line-height: 1.75;
  overflow-x: hidden;
}

/* ===== NOISE OVERLAY ===== */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 9999;
  opacity: 0.4;
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--accent2); border-radius: 3px; }

/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 4rem 2rem;
  overflow: hidden;
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridDrift 20s linear infinite;
}

@keyframes gridDrift {
  0% { transform: translateY(0); }
  100% { transform: translateY(60px); }
}

.hero-glow {
  position: absolute;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  border: 1px solid rgba(0,212,255,0.3);
  border-radius: 100px;
  background: rgba(0,212,255,0.05);
  color: var(--accent);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  position: relative;
  z-index: 1;
}

.hero-badge::before {
  content: '';
  width: 6px;
  height: 6px;
  background: var(--accent);
  border-radius: 50%;
  animation: blink 1.5s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.2; }
}

.hero h1 {
  font-family: var(--font-head);
  font-size: clamp(2.5rem, 6vw, 5.5rem);
  font-weight: 800;
  line-height: 1.05;
  position: relative;
  z-index: 1;
  letter-spacing: -0.02em;
}

.hero h1 .line1 { color: var(--text); display: block; }
.hero h1 .line2 {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 50%, var(--accent3) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}

.hero-sub {
  font-size: 14px;
  color: var(--text2);
  max-width: 600px;
  margin: 1.5rem auto 0;
  position: relative;
  z-index: 1;
  line-height: 1.8;
}

.hero-meta {
  display: flex;
  gap: 2rem;
  margin-top: 3rem;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
  justify-content: center;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.hero-stat .num {
  font-family: var(--font-head);
  font-size: 2rem;
  font-weight: 800;
  color: var(--accent);
}

.hero-stat .label {
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text3);
}

/* ===== TOC ===== */
.toc {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 2rem;
  margin: 3rem auto;
  max-width: 1200px;
  position: relative;
}

.toc::before {
  content: 'TABLE OF CONTENTS';
  display: block;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--accent);
  margin-bottom: 1.5rem;
  font-weight: 700;
}

.toc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 0.5rem;
}

.toc a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  color: var(--text2);
  text-decoration: none;
  border-radius: 6px;
  font-size: 12px;
  transition: all 0.2s;
  border: 1px solid transparent;
}

.toc a:hover {
  color: var(--accent);
  background: rgba(0,212,255,0.05);
  border-color: rgba(0,212,255,0.2);
}

.toc a .toc-num {
  font-size: 10px;
  color: var(--accent2);
  font-weight: 700;
  min-width: 24px;
  font-family: var(--font-head);
}

/* ===== LAYOUT ===== */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ===== SECTIONS ===== */
.section {
  margin: 5rem auto;
  max-width: 1200px;
  padding: 0 2rem;
}

.section-header {
  display: flex;
  align-items: flex-start;
  gap: 1.5rem;
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--border);
}

.section-num {
  font-family: var(--font-head);
  font-size: 4rem;
  font-weight: 800;
  color: rgba(124,58,237,0.2);
  line-height: 1;
  min-width: 80px;
}

.section-title-wrap {}

.section-tag {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 6px;
}

.section-title {
  font-family: var(--font-head);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.01em;
}

.section-desc {
  color: var(--text2);
  font-size: 13px;
  margin-top: 0.5rem;
  max-width: 700px;
}

/* ===== SUBSECTIONS ===== */
h2 {
  font-family: var(--font-head);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text);
  margin: 2.5rem 0 1rem;
  padding-left: 12px;
  border-left: 3px solid var(--accent2);
}

h3 {
  font-family: var(--font-head);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--accent3);
  margin: 2rem 0 0.75rem;
}

h4 {
  font-family: var(--font-head);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--accent4);
  margin: 1.5rem 0 0.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 11px;
}

p { margin: 0.75rem 0; color: var(--text2); }
strong { color: var(--text); font-weight: 700; }
em { color: var(--accent3); font-style: normal; }

/* ===== CODE ===== */
pre {
  background: var(--code-bg);
  border: 1px solid var(--code-border);
  border-radius: 8px;
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin: 1.25rem 0;
  position: relative;
}

pre::before {
  content: attr(data-lang);
  position: absolute;
  top: 8px;
  right: 12px;
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

code {
  font-family: var(--font-mono);
  font-size: 12.5px;
  color: #e6edf3;
  line-height: 1.6;
}

:not(pre) > code {
  background: rgba(110,64,229,0.15);
  border: 1px solid rgba(110,64,229,0.25);
  border-radius: 4px;
  padding: 1px 6px;
  font-size: 12px;
  color: #c9b1ff;
}

/* Syntax highlighting */
.kw { color: #ff7b72; }
.fn { color: #d2a8ff; }
.str { color: #a5d6ff; }
.cm { color: #8b949e; font-style: italic; }
.num { color: #79c0ff; }
.type { color: #ffa657; }
.op { color: #ff7b72; }
.var { color: #e6edf3; }
.prop { color: #79c0ff; }
.ann { color: #f0883e; }

/* ===== ASCII DIAGRAMS ===== */
.diagram {
  background: var(--code-bg);
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 8px;
  padding: 1.5rem;
  margin: 1.5rem 0;
  overflow-x: auto;
}

.diagram pre {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  color: var(--accent);
  font-size: 12px;
}

/* ===== CARDS ===== */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
  margin: 1.5rem 0;
}

.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.5rem;
  transition: border-color 0.2s, transform 0.2s;
}

.card:hover {
  border-color: var(--accent2);
  transform: translateY(-2px);
}

.card-icon {
  font-size: 1.5rem;
  margin-bottom: 0.75rem;
}

.card-title {
  font-family: var(--font-head);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.5rem;
}

.card-body {
  font-size: 12px;
  color: var(--text2);
  line-height: 1.7;
}

/* ===== CALLOUTS ===== */
.callout {
  display: flex;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  border-radius: 8px;
  margin: 1.5rem 0;
  border-left: 3px solid;
}

.callout-warn {
  background: rgba(245,158,11,0.06);
  border-color: var(--accent3);
}

.callout-info {
  background: rgba(0,212,255,0.05);
  border-color: var(--accent);
}

.callout-danger {
  background: rgba(239,68,68,0.06);
  border-color: var(--danger);
}

.callout-success {
  background: rgba(16,185,129,0.06);
  border-color: var(--accent4);
}

.callout-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
.callout-content { font-size: 12.5px; color: var(--text2); line-height: 1.7; }
.callout-title { font-family: var(--font-head); font-weight: 700; color: var(--text); margin-bottom: 0.25rem; font-size: 13px; }

/* ===== INTERVIEW QUESTIONS ===== */
.iq-box {
  background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(0,212,255,0.04));
  border: 1px solid rgba(124,58,237,0.3);
  border-radius: 10px;
  padding: 1.5rem;
  margin: 1.5rem 0;
}

.iq-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 1rem;
}

.iq-label {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent2);
  font-weight: 700;
}

.iq-level {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 100px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.lvl-senior { background: rgba(0,212,255,0.1); color: var(--accent); }
.lvl-staff { background: rgba(124,58,237,0.15); color: #c4b5fd; }
.lvl-faang { background: rgba(245,158,11,0.15); color: var(--accent3); }

.iq-q {
  font-family: var(--font-head);
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.75rem;
}

.iq-a {
  font-size: 12.5px;
  color: var(--text2);
  line-height: 1.75;
}

.iq-a strong { color: var(--accent4); }

/* ===== TABLES ===== */
.table-wrap { overflow-x: auto; margin: 1.5rem 0; }

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
}

thead th {
  background: var(--surface);
  padding: 10px 14px;
  text-align: left;
  font-family: var(--font-head);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text2);
  border-bottom: 1px solid var(--border);
}

tbody td {
  padding: 10px 14px;
  border-bottom: 1px solid rgba(42,42,74,0.5);
  color: var(--text2);
  vertical-align: top;
}

tbody tr:hover td { background: rgba(255,255,255,0.02); }
tbody td:first-child { color: var(--text); font-weight: 600; }

/* ===== TIMELINE ===== */
.timeline {
  position: relative;
  padding-left: 2rem;
  margin: 1.5rem 0;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--accent2), var(--accent));
}

.tl-item {
  position: relative;
  margin-bottom: 1.5rem;
  padding-left: 1rem;
}

.tl-item::before {
  content: '';
  position: absolute;
  left: -1.55rem;
  top: 6px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
}

.tl-title {
  font-family: var(--font-head);
  font-weight: 700;
  color: var(--text);
  font-size: 0.9rem;
  margin-bottom: 0.25rem;
}

.tl-body { font-size: 12px; color: var(--text2); }

/* ===== DIFF / COMPARISON ===== */
.diff-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin: 1.5rem 0;
}

.diff-col {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
}

.diff-col.good { border-color: rgba(16,185,129,0.3); }
.diff-col.bad { border-color: rgba(239,68,68,0.3); }

.diff-label {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 0.75rem;
}

.good .diff-label { color: var(--accent4); }
.bad .diff-label { color: var(--danger); }

/* ===== BADGES ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin: 0 2px;
}

.badge-android { background: rgba(61,220,132,0.12); color: #3ddc84; border: 1px solid rgba(61,220,132,0.2); }
.badge-ios { background: rgba(0,122,255,0.1); color: #007aff; border: 1px solid rgba(0,122,255,0.2); }
.badge-js { background: rgba(247,223,30,0.1); color: #f7df1e; border: 1px solid rgba(247,223,30,0.2); }
.badge-rn { background: rgba(97,218,251,0.1); color: #61dafb; border: 1px solid rgba(97,218,251,0.2); }
.badge-perf { background: rgba(245,158,11,0.1); color: var(--accent3); border: 1px solid rgba(245,158,11,0.2); }
.badge-arch { background: rgba(124,58,237,0.1); color: #c4b5fd; border: 1px solid rgba(124,58,237,0.2); }

/* ===== INCIDENT BOX ===== */
.incident {
  background: rgba(239,68,68,0.04);
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 10px;
  padding: 1.5rem;
  margin: 1.5rem 0;
}

.incident-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 1rem;
}

.incident-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--danger);
  padding: 3px 8px;
  background: rgba(239,68,68,0.1);
  border-radius: 4px;
}

.incident-title {
  font-family: var(--font-head);
  font-weight: 700;
  color: var(--text);
  font-size: 0.95rem;
}

/* ===== DIVIDER ===== */
.divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 3rem 0;
}

/* ===== NAVIGATION ===== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(10,10,15,0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-family: var(--font-head);
  font-weight: 800;
  font-size: 0.9rem;
  color: var(--text);
  letter-spacing: -0.02em;
}

.nav-logo span { color: var(--accent); }

.nav-links {
  display: flex;
  gap: 0.25rem;
  overflow-x: auto;
}

.nav-links a {
  color: var(--text3);
  text-decoration: none;
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 4px;
  transition: all 0.2s;
  white-space: nowrap;
}

.nav-links a:hover { color: var(--accent); background: rgba(0,212,255,0.06); }

/* ===== BACK TO TOP ===== */
.back-top {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  width: 42px;
  height: 42px;
  background: var(--accent2);
  color: white;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  transition: transform 0.2s, opacity 0.2s;
  z-index: 200;
  text-decoration: none;
}

.back-top:hover { transform: translateY(-3px); }

/* ===== UL/OL ===== */
ul, ol {
  padding-left: 1.5rem;
  margin: 0.75rem 0;
  color: var(--text2);
}

li {
  margin: 0.35rem 0;
  font-size: 13px;
  line-height: 1.65;
}

li strong { color: var(--text); }

/* ===== ROADMAP ===== */
.roadmap-track {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
  margin: 1.5rem 0;
}

.roadmap-week {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem;
}

.roadmap-week-label {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.5rem;
}

.roadmap-week h4 {
  font-size: 12px;
  color: var(--text);
  margin: 0 0 0.5rem;
  text-transform: none;
  letter-spacing: 0;
}

.roadmap-week ul { margin: 0; padding-left: 1rem; }
.roadmap-week li { font-size: 11px; margin: 0.2rem 0; }

/* PAGE BREAK */
.page-break { margin: 6rem 0; }

/* ===== TAG CHIPS ===== */
.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.75rem 0; }
.tag {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 100px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--text3);
  letter-spacing: 0.05em;
}

/* ===== PRINT STYLES ===== */
@media print {
  .nav, .back-top { display: none; }
  body { background: white; color: black; }
}

/* ===== ANIMATIONS ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.section { animation: fadeInUp 0.5s ease both; }
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-logo">RN <span>STAFF</span> MANUAL</div>
  <div class="nav-links">
    <a href="#android">Android</a>
    <a href="#ios">iOS</a>
    <a href="#react">React</a>
    <a href="#js-engine">JS Engine</a>
    <a href="#distributed">Distributed</a>
