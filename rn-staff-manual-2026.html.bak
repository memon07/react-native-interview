  <h2>React Render Optimization — Complete Guide</h2>

  <pre data-lang="TypeScript"><code>// The render optimization checklist

// 1. Memo: prevent re-render if props unchanged
const ProductCard = React.memo(({ product, onAdd }: Props) => {
  return <View>...</View>;
}, (prevProps, nextProps) => {
  // Custom comparator: return true to SKIP re-render
  return prevProps.product.id === nextProps.product.id &&
         prevProps.product.price === nextProps.product.price;
});

// 2. useCallback: stable function reference
// BAD: new function every render → breaks memo
const onAdd = () => addToCart(product.id);

// GOOD: stable reference
const onAdd = useCallback(() => {
  addToCart(product.id);
}, [product.id]); // only changes when product.id changes

// 3. useMemo: expensive computation
// BAD: recomputes every render
const sortedProducts = products.sort(...);

// GOOD: only recomputes when products changes
const sortedProducts = useMemo(
  () => [...products].sort((a, b) => a.price - b.price),
  [products]
);

// 4. Context splitting: prevent over-subscription
// BAD: AuthContext has user AND theme → theme changes re-render auth consumers
const AppContext = createContext({ user, theme, cart });

// GOOD: separate contexts
const UserContext = createContext(user);    // rarely changes
const ThemeContext = createContext(theme);  // changes on dark mode toggle
const CartContext = createContext(cart);    // changes on add/remove

// 5. State colocation: keep state close to where it's used
// BAD: lift modal state to App root → entire tree re-renders on open
function App() {
  const [isModalOpen, setIsModalOpen] = useState(false); // BAD

// GOOD: colocate in the component that uses it
function ProductCard() {
  const [isModalOpen, setIsModalOpen] = useState(false); // isolated</code></pre>

  <h2>FlashList — Why It's Faster than FlatList</h2>

  <div class="diagram">
<pre>
FLATLIST vs FLASHLIST INTERNALS

FlatList (VirtualizedList):
  - Uses absolute positioning for each item
  - JavaScript measures item height → Main Thread
  - RecyclerViewViewabilityHelper in JS → slow
  - Blank cells during fast scroll (render lag)
  - Default windowSize: 21 (renders 10 screens ahead)

FlashList:
  - Recycling pools (like RecyclerView on Android)
  - Reuses existing component instances (no unmount/remount)
  - estimatedItemSize → skip initial height measurement
  - renderItem doesn't receive index (encourages pure components)
  - Blank fill threshold: 250ms not frames
  - 10x fewer layout calculations

KEY REQUIREMENT:
  - Items must be uniform height OR use overrideItemLayout
  - getItemType for mixed-type lists (separate pools per type)
  - keyExtractor not needed if items have stable .id
</pre>
  </div>

  <pre data-lang="TypeScript"><code>// FlashList production setup
import { FlashList } from "@shopify/flash-list";

const Feed = () => {
  const { data, fetchNextPage, hasNextPage } = useInfiniteQuery(...);
  const allItems = useMemo(
    () => data?.pages.flatMap(p => p.items) ?? [],
    [data]
  );

  const renderItem = useCallback(({ item }: { item: FeedItem }) => {
    return <FeedCard item={item} />;
  }, []); // no deps → always stable, FlashList reuses instances

  return (
    <FlashList
      data={allItems}
      renderItem={renderItem}
      estimatedItemSize={120}   // critical: measure your items!
      keyExtractor={item => item.id}
      getItemType={item => item.type} // 'post' | 'ad' | 'story'
      onEndReached={fetchNextPage}
      onEndReachedThreshold={0.5}
      maintainVisibleContentPosition={{ minIndexForVisible: 0 }}
      drawDistance={500} // px above/below viewport to pre-render
    />
  );
};</code></pre>

  <h2>Reanimated 3 — Worklet Architecture</h2>

  <div class="diagram">
<pre>
REANIMATED ARCHITECTURE

JS Thread                     UI Thread (native)
─────────                     ──────────────────
useState, props               Worklets: run on UI thread
shared values ─────────────► SharedValue (native)
                              Animation drivers
                              (CADisplayLink / Choreographer)
                              Modify native props directly
                              (no bridge for each frame!)

vs Animated API:
  Animated: calculates in JS, sends values over bridge (each frame!)
  Reanimated: calculates on UI thread → zero bridge per frame
  Result: 60/120fps even when JS thread is busy

WORKLET: function that runs on UI thread
  'worklet' directive at top of function
  Cannot access JS-side closure arbitrarily
  Can access: SharedValues, other worklets, style props
</pre>
  </div>

  <pre data-lang="TypeScript"><code>// Production Reanimated 3 patterns
import Animated, {
  useSharedValue, useAnimatedStyle,
  withSpring, withTiming, interpolate,
  useAnimatedGestureHandler, runOnJS
} from 'react-native-reanimated';

// Gesture-driven animation (zero JS involvement per frame)
const Swipeable = ({ onDismiss }: { onDismiss: () => void }) => {
  const translateX = useSharedValue(0);
  const opacity = useSharedValue(1);

  const gestureHandler = useAnimatedGestureHandler({
    onStart: (_, ctx: any) => {
      ctx.startX = translateX.value;
    },
    onActive: (event, ctx) => {
      translateX.value = ctx.startX + event.translationX;
      opacity.value = interpolate(
        Math.abs(translateX.value), [0, 200], [1, 0]
      );
    },
    onEnd: (event) => {
      if (Math.abs(event.translationX) > 120) {
        translateX.value = withTiming(500);
        runOnJS(onDismiss)(); // call JS from worklet
      } else {
        translateX.value = withSpring(0);
        opacity.value = withSpring(1);
      }
    },
  });

  const animStyle = useAnimatedStyle(() => ({
    transform: [{ translateX: translateX.value }],
    opacity: opacity.value,
  })); // runs on UI thread, no re-render

  return (
    <PanGestureHandler onGestureEvent={gestureHandler}>
      <Animated.View style={[styles.card, animStyle]} />
    </PanGestureHandler>
  );
};</code></pre>

  <h2>App Startup Optimization</h2>

  <div class="diagram">
<pre>
STARTUP PHASES & OPTIMIZATION TARGETS

Cold Start Timeline (target: < 2.5s TTI)

[0ms]   App process created
[50ms]  SO libraries loaded (libhermes, libfabric, etc.)
        OPTIMIZE: Enable ZSTD compression for SO files (Android 14)
[150ms] RN host initialized, bridge/JSI started
        OPTIMIZE: Lazy-init non-critical native modules
[300ms] Hermes loads bytecode
        OPTIMIZE: hermes -O flag, ensure .hbc not .js
[500ms] JS bundle executes (module registry setup)
        OPTIMIZE: Remove unused imports, tree-shake, lazy routes
[700ms] React renders first component tree
        OPTIMIZE: Suspense + lazy for heavy screens
[900ms] First paint (splash → actual content)
        OPTIMIZE: Preload above-fold data before RN starts
[1200ms] Time To Interactive (touches respond)
        OPTIMIZE: Defer non-critical init post-interaction

MEASUREMENT:
  Android: adb shell am start -W com.myapp/.MainActivity
           → "TotalTime: 1243ms"
  iOS: os_signpost in Xcode Instruments
       Or: RN Startup Profiler (Meta's internal tool, open-sourced)
  Both: Flipper Startup → flame chart
</pre>
  </div>

  <pre data-lang="TypeScript"><code">// Metro config for bundle optimization
// metro.config.js
module.exports = {
  transformer: {
    minifierConfig: {
      keep_fnames: false,
      mangle: { keep_fnames: false },
      compress: {
        drop_console: true,  // remove console.log in prod
        pure_funcs: ['console.log', 'console.info'],
      },
    },
  },
  serializer: {
    // RAM bundles: load modules on-demand
    createModuleIdFactory: () => createRamBundleModuleId(),
  },
};

// Lazy route loading: defer heavy screens
const HeavyScreen = React.lazy(() =>
  import('./screens/HeavyScreen')
    .then(module => ({ default: module.HeavyScreen }))
);

// Preload critical data before bundle executes
// In native: fetch /config endpoint during splash screen display
// Pass to RN as initial props
const rootView = RCTFabricSurfaceHostingProxyRootView(
  bridge: bridge,
  moduleName: "App",
  initialProperties: ["preloadedUser": configFromSplash]
);</code></pre>

